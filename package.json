{
  "name": "@zero-dash/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build:prod": "dotenv -- npx nx run-many --target=build --all --configuration=production",
    "build:prod:affected": "dotenv -- npx nx affected --target=build --configuration=production",
    "start:dev:core": "dotenv -- npx nx run-many --parallel 6 -t start:dev -p zero-dash-gateway,zero-dash-api,zero-dash-clinical,zero-dash-reports,zero-dash-frontend,zero-dash-evidence",
    "start:dev:extended": "dotenv -- npx nx run-many --parallel 8 -t start:dev -p zero-dash-gateway,zero-dash-api,zero-dash-clinical,zero-dash-reports,zero-dash-frontend,zero-dash-evidence,zero-dash-drugs",
    "start:dev:all": "dotenv -- npx nx run-many --parallel 15 -t start:dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@nx/docker": "22.4.5",
    "@nx/eslint": "22.1.3",
    "@nx/js": "22.4.5",
    "@nx/web": "22.4.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.11",
    "@swc/helpers": "~0.5.17",
    "@types/confusing-browser-globals": "^1.0.3",
    "@types/eslint": "^9.6.1",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/object.assign": "^4.1.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/ui": "^4.0.18",
    "confusing-browser-globals": "^1.0.11",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-styled-components-varname": "^1.0.1",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.4.5",
    "object.assign": "^4.1.7",
    "semver": "^7.7.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "overrides": {
    "node-xlsx": {
      "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
    },
    "slate-dom": "0.119.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
