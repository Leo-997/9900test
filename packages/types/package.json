{
  "name": "@zero-dash/types",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "start:dev": "tsc --watch",
    "build": "tsc"
  },
  "dependencies": {
    "@nestjs/graphql": "^13.2.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "graphql-type-json": "^0.3.2",
    "tslib": "^2.8.1"
  },
  "nx": {
    "targets": {
      "install": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm install -w packages/types --ignore-scripts"
        }
      },
      "build": {
        "dependsOn": [
          "install"
        ]
      }
    }
  }
}
